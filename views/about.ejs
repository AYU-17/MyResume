<%- include('partials/header', { title: 'About Me' }) %>
<%- include('partials/navbar', { activePage: 'about' }) %>

<div class="bg-[#0f172a] text-white overflow-hidden min-h-screen pt-20 flex items-center">
  <section id="about" class="relative py-16 md:py-28 overflow-hidden w-full">

    <!-- Background Glows -->
    <div class="absolute top-0 left-0 w-[300px] h-[300px] bg-cyan-500/10 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-0 right-0 w-[300px] h-[300px] bg-purple-500/10 blur-[120px] rounded-full"></div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- LEFT SIDE IMAGE -->
        <div class="relative flex justify-center" data-aos="fade-right" data-aos-duration="1000">
          <!-- Glow -->
          <div class="absolute w-[300px] h-[300px] bg-cyan-500/20 blur-[100px] rounded-full"></div>

          <!-- Image -->
          <img
            src="/assets/profile.png"
            alt="About Aayush"
            class="relative w-[280px] sm:w-[350px] rounded-3xl border border-white/10 shadow-2xl object-cover"
          />
        </div>

        <!-- RIGHT SIDE CONTENT -->
        <div data-aos="fade-left" data-aos-duration="1000">
          <!-- Small Heading -->
          <p class="text-cyan-400 uppercase tracking-[4px] mb-4 font-semibold">
            About Me
          </p>

          <!-- Main Heading -->
          <h2 class="text-4xl md:text-5xl font-bold leading-tight">
            Building Modern
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-500">
              Full Stack
            </span>
            <br />
            Web Experiences
          </h2>

          <!-- Description -->
          <p class="text-gray-400 leading-8 mt-8">
            I enjoy building full-stack applications that solve real-world problems with clean UI and efficient backend systems.
          </p>

          <p class="text-gray-400 leading-8 mt-6">
            Currently pursuing MCA while building production-ready projects using the MERN stack and realtime technologies.
          </p>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-4 sm:gap-6 mt-12">
            <% 
              const stats = [
                { number: "3+", label: "Projects" },
                { number: "5+", label: "Technologies" },
                { number: "100+", label: "Coding Hours" }
              ];
            %>
            <% stats.forEach(function(item) { %>
              <div class="bg-white/5 border border-white/10 rounded-2xl sm:rounded-3xl p-4 sm:p-6 text-center backdrop-blur-xl transition-all duration-300 hover:-translate-y-2 hover:border-cyan-400/40">
                <h3 class="text-2xl sm:text-3xl font-bold text-cyan-400">
                  <%= item.number %>
                </h3>
                <p class="text-gray-400 mt-2 text-xs sm:text-sm">
                  <%= item.label %>
                </p>
              </div>
            <% }); %>
          </div>

        </div>

      </div>
    </div>
  </section>
</div>

<%- include('partials/footer') %>
