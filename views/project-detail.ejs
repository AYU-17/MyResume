<%- include('partials/header', { title: project.title }) %>
<%- include('partials/navbar', { activePage: 'projects' }) %>

<!-- ============================================================ -->
<!--  SECTION 1: CINEMATIC HERO                                    -->
<!-- ============================================================ -->
<section class="relative min-h-[92vh] flex items-end pb-20 overflow-hidden">
  <!-- Hero Background Image -->
  <div class="absolute inset-0">
    <img src="<%= project.image %>" alt="<%= project.title %>" class="w-full h-full object-cover scale-105 hero-zoom"/>
    <!-- Layered dark overlays -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#0f172a] via-[#0f172a]/70 to-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#0f172a]/60 to-transparent"></div>
  </div>

  <!-- Animated Background Orbs -->
  <div class="absolute top-20 right-20 w-96 h-96 bg-cyan-500/10 rounded-full blur-[120px] animate-pulse-slow"></div>
  <div class="absolute bottom-20 left-10 w-80 h-80 bg-purple-500/10 rounded-full blur-[100px] animate-pulse-slow"></div>

  <!-- Hero Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 w-full">
    <!-- Back button -->
    <a href="/projects" class="inline-flex items-center gap-2 text-gray-400 hover:text-cyan-400 transition-colors duration-300 mb-10 group text-sm">
      <i class="fa-solid fa-arrow-left group-hover:-translate-x-1 transition-transform duration-300"></i>
      Back to Projects
    </a>

    <div class="max-w-4xl" data-aos="fade-up" data-aos-duration="800">
      <!-- Category Badge -->
      <div class="flex items-center gap-3 mb-6">
        <span class="px-4 py-1.5 rounded-full bg-cyan-500/15 border border-cyan-400/30 text-cyan-300 text-xs font-semibold uppercase tracking-widest">
          <%= project.category %>
        </span>
        <span class="flex items-center gap-1.5 text-green-400 text-xs font-medium">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse inline-block"></span>
          <%= project.status %>
        </span>
      </div>

      <!-- Title -->
      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight mb-5">
        <span class="text-white"><%= project.title.split(' ')[0] %>&nbsp;</span>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-500">
          <%= project.title.split(' ').slice(1).join(' ') %>
        </span>
      </h1>

      <!-- Tagline -->
      <p class="text-gray-300 text-xl md:text-2xl font-light mb-8 max-w-2xl leading-relaxed">
        <%= project.tagline %>
      </p>

      <!-- Tech Stack Badges -->
      <div class="flex flex-wrap gap-2.5 mb-10">
        <% project.tech.forEach(function(t) { %>
          <span class="px-3 py-1.5 rounded-xl bg-white/10 border border-white/20 backdrop-blur-sm text-white text-xs font-medium hover:border-cyan-400/50 hover:bg-cyan-500/10 transition-all duration-300">
            <%= t %>
          </span>
        <% }); %>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-4">
        <% if (project.demo && project.demo !== '#') { %>
        <a href="<%= project.demo %>" target="_blank" rel="noopener noreferrer"
          class="group/btn flex items-center gap-2 px-7 py-3.5 rounded-2xl bg-gradient-to-r from-cyan-500 to-purple-500 font-semibold text-white hover:scale-105 hover:shadow-xl hover:shadow-cyan-500/25 transition-all duration-300 active:scale-95">
          <i class="fa-solid fa-arrow-up-right-from-square text-sm group-hover/btn:rotate-12 transition-transform duration-300"></i>
          Live Demo
        </a>
        <% } %>
        <a href="<%= project.github %>" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-2 px-7 py-3.5 rounded-2xl bg-white/10 border border-white/20 backdrop-blur-sm font-semibold hover:border-cyan-400 hover:bg-white/15 transition-all duration-300 hover:scale-105">
          <i class="fa-brands fa-github text-lg"></i>
          View Code
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#0f172a] to-transparent"></div>
</section>

<!-- ============================================================ -->
<!--  MAIN CONTENT WRAPPER                                         -->
<!-- ============================================================ -->
<div class="bg-[#0f172a] relative">
  <!-- Ambient glows -->
  <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-cyan-500/5 rounded-full blur-[150px] pointer-events-none"></div>
  <div class="absolute top-1/2 right-0 w-[400px] h-[400px] bg-purple-500/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 py-24 space-y-32">

    <!-- ========================================================= -->
    <!--  SECTION 2: PROJECT OVERVIEW                               -->
    <!-- ========================================================= -->
    <div data-aos="fade-up" data-aos-duration="700">
      <div class="section-label mb-3">Project Overview</div>
      <h2 class="section-heading mb-12">About This <span class="gradient-text">Project</span></h2>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
        <!-- Description (left, wider) -->
        <div class="lg:col-span-3 space-y-6">
          <p class="text-gray-300 text-lg leading-8">
            <%= project.overview.description %>
          </p>
          <div class="p-6 rounded-2xl bg-white/5 border border-white/10">
            <h4 class="text-cyan-400 font-semibold mb-2 text-sm uppercase tracking-widest">🎯 Objective</h4>
            <p class="text-gray-400 leading-7 text-sm"><%= project.overview.objective %></p>
          </div>
          <div class="p-6 rounded-2xl bg-white/5 border border-white/10">
            <h4 class="text-purple-400 font-semibold mb-2 text-sm uppercase tracking-widest">⚡ Problem Solved</h4>
            <p class="text-gray-400 leading-7 text-sm"><%= project.overview.problemSolved %></p>
          </div>
        </div>

        <!-- Info Cards (right) -->
        <div class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-4">
          <%
            const infoItems = [
              { icon: 'fa-solid fa-tag', label: 'Project Type', value: project.overview.type, color: 'text-cyan-400' },
              { icon: 'fa-solid fa-clock', label: 'Duration', value: project.overview.duration, color: 'text-purple-400' },
              { icon: 'fa-solid fa-users', label: 'Team Size', value: project.overview.teamSize, color: 'text-green-400' },
              { icon: 'fa-solid fa-code', label: 'My Role', value: project.overview.role, color: 'text-yellow-400' },
              { icon: 'fa-solid fa-circle-check', label: 'Status', value: project.overview.status, color: 'text-emerald-400' },
            ];
          %>
          <% infoItems.forEach(function(item) { %>
          <div class="flex items-center gap-4 p-4 rounded-2xl bg-white/5 border border-white/10 hover:border-cyan-400/30 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center flex-shrink-0">
              <i class="<%= item.icon %> <%= item.color %> text-sm"></i>
            </div>
            <div>
              <p class="text-gray-500 text-xs uppercase tracking-widest"><%= item.label %></p>
              <p class="text-white font-semibold text-sm"><%= item.value %></p>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </div>

    <!-- ========================================================= -->
    <!--  SECTION 3: KEY FEATURES                                   -->
    <!-- ========================================================= -->
    <div data-aos="fade-up" data-aos-duration="700">
      <div class="section-label mb-3">Capabilities</div>
      <h2 class="section-heading mb-12">Key <span class="gradient-text">Features</span></h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% project.features.forEach(function(feat, idx) { %>
        <div class="group relative" data-aos="fade-up" data-aos-delay="<%= idx * 80 %>">
          <!-- Glow -->
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-cyan-500 to-purple-500 blur-xl opacity-0 group-hover:opacity-15 transition-all duration-500"></div>
          <div class="relative p-6 rounded-2xl bg-white/5 border border-white/10 h-full hover:border-cyan-400/40 transition-all duration-300 group-hover:translate-y-[-4px]">
            <div class="text-3xl mb-4"><%= feat.icon %></div>
            <h3 class="text-white font-bold text-base mb-2"><%= feat.name %></h3>
            <p class="text-gray-400 text-sm leading-6"><%= feat.description %></p>
          </div>
        </div>
        <% }); %>
      </div>
    </div>

    <!-- ========================================================= -->
    <!--  SECTION 4: TECHNOLOGY STACK                               -->
    <!-- ========================================================= -->
    <div data-aos="fade-up" data-aos-duration="700">
      <div class="section-label mb-3">Built With</div>
      <h2 class="section-heading mb-12">Technology <span class="gradient-text">Stack</span></h2>

      <div class="flex flex-wrap gap-4">
        <% project.techStack.forEach(function(t, idx) { %>
        <div class="group relative" data-aos="zoom-in" data-aos-delay="<%= idx * 60 %>">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br <%= t.gradient %> blur-lg opacity-0 group-hover:opacity-30 transition-all duration-400"></div>
          <div class="relative flex items-center gap-3 px-5 py-3 rounded-2xl bg-white/5 border border-white/10 hover:border-white/30 transition-all duration-300 cursor-default group-hover:scale-105">
            <span class="text-xl"><%= t.icon %></span>
            <div>
              <p class="text-white font-semibold text-sm"><%= t.name %></p>
              <p class="text-gray-400 text-xs"><%= t.type %></p>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>

    <!-- ========================================================= -->
    <!--  SECTION 5: SYSTEM ARCHITECTURE                            -->
    <!-- ========================================================= -->
    <div data-aos="fade-up" data-aos-duration="700">
      <div class="section-label mb-3">System Design</div>
      <h2 class="section-heading mb-12">Architecture <span class="gradient-text">Flow</span></h2>

      <div class="flex flex-col md:flex-row items-center justify-center gap-0 flex-wrap">
        <% project.architecture.forEach(function(layer, idx) { %>
          <!-- Architecture Card -->
          <div class="flex flex-col md:flex-row items-center" data-aos="fade-<%= idx % 2 === 0 ? 'right' : 'left' %>" data-aos-delay="<%= idx * 100 %>">
            <div class="group relative">
              <div class="absolute inset-0 rounded-2xl bg-gradient-to-br <%= layer.gradient %> blur-lg opacity-20 group-hover:opacity-40 transition-all duration-500"></div>
              <div class="relative p-6 rounded-2xl bg-white/5 border border-white/10 hover:border-white/30 transition-all duration-300 text-center min-w-[160px] group-hover:scale-105">
                <div class="text-3xl mb-2"><%= layer.icon %></div>
                <h4 class="text-white font-bold text-sm"><%= layer.name %></h4>
                <p class="text-gray-500 text-xs mt-1"><%= layer.detail %></p>
              </div>
            </div>
            <% if (idx < project.architecture.length - 1) { %>
              <!-- Arrow -->
              <div class="flex items-center justify-center text-cyan-400/50 my-2 md:my-0 md:mx-3 text-xl rotate-90 md:rotate-0">
                <i class="fa-solid fa-chevron-right"></i>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>

    <!-- ========================================================= -->
    <!--  SECTION 6: CHALLENGES & SOLUTIONS                         -->
    <!-- ========================================================= -->
    <div data-aos="fade-up" data-aos-duration="700">
      <div class="section-label mb-3">Problem Solving</div>
      <h2 class="section-heading mb-12">Challenges & <span class="gradient-text">Solutions</span></h2>

      <div class="space-y-6">
        <% project.challenges.forEach(function(ch, idx) { %>
        <div class="group grid grid-cols-1 md:grid-cols-2 gap-0 rounded-2xl overflow-hidden border border-white/10 hover:border-white/20 transition-all duration-300" data-aos="fade-up" data-aos-delay="<%= idx * 100 %>">
          <!-- Challenge -->
          <div class="p-6 bg-red-500/5 border-b md:border-b-0 md:border-r border-white/10">
            <div class="flex items-center gap-2 mb-3">
              <i class="fa-solid fa-triangle-exclamation text-red-400 text-sm"></i>
              <span class="text-red-400 text-xs font-semibold uppercase tracking-widest">Challenge</span>
            </div>
            <p class="text-gray-300 text-sm leading-7"><%= ch.challenge %></p>
          </div>
          <!-- Solution -->
          <div class="p-6 bg-green-500/5">
            <div class="flex items-center gap-2 mb-3">
              <i class="fa-solid fa-lightbulb text-green-400 text-sm"></i>
              <span class="text-green-400 text-xs font-semibold uppercase tracking-widest">Solution</span>
            </div>
            <p class="text-gray-300 text-sm leading-7"><%= ch.solution %></p>
          </div>
        </div>
        <% }); %>
      </div>
    </div>

    <!-- ========================================================= -->
    <!--  SECTION 7: DEVELOPMENT TIMELINE                           -->
    <!-- ========================================================= -->
    <div data-aos="fade-up" data-aos-duration="700">
      <div class="section-label mb-3">Journey</div>
      <h2 class="section-heading mb-16">Development <span class="gradient-text">Timeline</span></h2>

      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-cyan-500/50 via-purple-500/50 to-transparent transform md:-translate-x-px"></div>

        <div class="space-y-10">
          <% project.timeline.forEach(function(step, idx) { %>
          <div class="relative flex items-start gap-8 md:gap-0 <%= idx % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse' %>" data-aos="<%= idx % 2 === 0 ? 'fade-right' : 'fade-left' %>" data-aos-delay="<%= idx * 100 %>">
            <!-- Timeline dot (center) -->
            <div class="absolute left-6 md:left-1/2 w-3 h-3 rounded-full bg-cyan-400 border-2 border-[#0f172a] shadow-lg shadow-cyan-400/50 transform md:-translate-x-1.5 mt-5 z-10"></div>

            <!-- Empty spacer for alternating layout -->
            <div class="hidden md:block md:w-1/2"></div>

            <!-- Content card -->
            <div class="ml-14 md:ml-0 md:w-1/2 <%= idx % 2 === 0 ? 'md:pl-10' : 'md:pr-10 md:text-right' %>">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-400/20 text-cyan-300 text-xs font-medium mb-3">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-400"></span>
                Step <%= idx + 1 %>
              </div>
              <div class="p-5 rounded-2xl bg-white/5 border border-white/10 hover:border-cyan-400/30 transition-all duration-300">
                <h4 class="text-white font-bold mb-1.5"><%= step.phase %></h4>
                <p class="text-gray-400 text-sm leading-6"><%= step.description %></p>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </div>

    <!-- ========================================================= -->
    <!--  SECTION 8: RESULTS & STATS                                -->
    <!-- ========================================================= -->
    <div data-aos="fade-up" data-aos-duration="700">
      <div class="section-label mb-3">Achievements</div>
      <h2 class="section-heading mb-12">Results & <span class="gradient-text">Impact</span></h2>

      <!-- Stats Grid -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5 mb-10">
        <% project.stats.forEach(function(stat, idx) { %>
        <div class="group relative text-center" data-aos="zoom-in" data-aos-delay="<%= idx * 80 %>">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-cyan-500 to-purple-500 blur-xl opacity-0 group-hover:opacity-20 transition-all duration-500"></div>
          <div class="relative p-6 rounded-2xl bg-white/5 border border-white/10 hover:border-cyan-400/30 transition-all duration-300">
            <div class="text-3xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-500 counter-number" data-target="<%= stat.number %>">
              0
            </div>
            <div class="text-gray-400 text-xs mt-2 font-medium"><%= stat.label %></div>
          </div>
        </div>
        <% }); %>
      </div>

      <!-- Achievement Checklist -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <% project.achievements.forEach(function(ach) { %>
        <div class="flex items-center gap-3 p-4 rounded-xl bg-white/5 border border-white/10 hover:border-green-400/30 transition-all duration-300" data-aos="fade-up">
          <div class="w-6 h-6 rounded-full bg-green-500/15 border border-green-400/30 flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-check text-green-400 text-xs"></i>
          </div>
          <span class="text-gray-300 text-sm"><%= ach %></span>
        </div>
        <% }); %>
      </div>
    </div>

    <!-- ========================================================= -->
    <!--  SECTION 9: FINAL CTA                                      -->
    <!-- ========================================================= -->
    <div class="relative overflow-hidden" data-aos="fade-up" data-aos-duration="700">
      <!-- Gradient glow background -->
      <div class="absolute inset-0 rounded-3xl bg-gradient-to-r from-cyan-500/10 via-purple-500/10 to-cyan-500/10"></div>
      <div class="absolute inset-0 rounded-3xl border border-white/10"></div>
      <!-- Floating orbs inside CTA -->
      <div class="absolute -top-10 -right-10 w-40 h-40 bg-cyan-400/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-purple-400/10 rounded-full blur-3xl"></div>

      <div class="relative p-10 md:p-16 text-center rounded-3xl">
        <p class="text-cyan-400 uppercase tracking-[4px] text-xs font-semibold mb-4">
          Explore More
        </p>
        <h2 class="text-3xl md:text-5xl font-extrabold mb-4">
          Interested in <span class="gradient-text">this project?</span>
        </h2>
        <p class="text-gray-400 max-w-xl mx-auto mb-10 leading-7">
          Check out the live demo, dive into the source code, or explore more of my work below.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <% if (project.demo && project.demo !== '#') { %>
          <a href="<%= project.demo %>" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 px-8 py-4 rounded-2xl bg-gradient-to-r from-cyan-500 to-purple-500 font-bold hover:scale-105 hover:shadow-2xl hover:shadow-cyan-500/30 transition-all duration-300 active:scale-95">
            <i class="fa-solid fa-rocket text-sm"></i>
            Live Demo
          </a>
          <% } %>
          <a href="<%= project.github %>" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 px-8 py-4 rounded-2xl bg-white/5 border border-white/20 font-semibold hover:border-cyan-400 hover:bg-white/10 transition-all duration-300 hover:scale-105">
            <i class="fa-brands fa-github text-lg"></i>
            GitHub Repo
          </a>
          <a href="/projects"
            class="flex items-center gap-2 px-8 py-4 rounded-2xl bg-white/5 border border-white/20 font-semibold hover:border-purple-400 hover:bg-white/10 transition-all duration-300 hover:scale-105">
            <i class="fa-solid fa-grid-2 text-sm"></i>
            All Projects
          </a>
        </div>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>

<!-- ============================================================ -->
<!--  GLOBAL STYLES                                                -->
<!-- ============================================================ -->
<style>
  .section-label {
    display: inline-block;
    color: #22d3ee;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
  }
  .section-heading {
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    font-weight: 800;
    color: white;
    line-height: 1.2;
  }
  .gradient-text {
    background: linear-gradient(135deg, #22d3ee, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-zoom {
    animation: heroZoom 12s ease-in-out infinite alternate;
  }
  @keyframes heroZoom {
    from { transform: scale(1.05); }
    to   { transform: scale(1.12); }
  }
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.05); }
  }
  .animate-pulse-slow { animation: pulse-slow 5s ease-in-out infinite; }
</style>

<!-- ============================================================ -->
<!--  SCRIPTS: AOS + Counter Animation                             -->
<!-- ============================================================ -->
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
  AOS.init({ once: true, offset: 60 });

  // Animated counters
  function animateCounters() {
    document.querySelectorAll('.counter-number').forEach(function(el) {
      const target = parseInt(el.dataset.target, 10);
      if (isNaN(target)) { el.textContent = el.dataset.target; return; }
      let current = 0;
      const step  = Math.ceil(target / 50);
      const timer = setInterval(function() {
        current += step;
        if (current >= target) { current = target; clearInterval(timer); }
        el.textContent = current + '+';
      }, 30);
    });
  }

  // Trigger counters when stats section enters viewport
  const statsObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        animateCounters();
        statsObserver.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const firstCounter = document.querySelector('.counter-number');
  if (firstCounter) statsObserver.observe(firstCounter.closest('div[data-aos]') || firstCounter);
</script>
