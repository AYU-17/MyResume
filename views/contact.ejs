<%- include('partials/header', { title: 'Contact Me' }) %>
<%- include('partials/navbar', { activePage: 'contact' }) %>

<div class="bg-[#0f172a] text-white overflow-hidden min-h-screen pt-20 flex items-center">
  <section id="contact" class="relative py-16 md:py-28 overflow-hidden w-full">

    <!-- Background Glows -->
    <div class="absolute top-0 left-0 w-[300px] h-[300px] bg-cyan-500/10 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-0 right-0 w-[300px] h-[300px] bg-purple-500/10 blur-[120px] rounded-full"></div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">

      <!-- Heading -->
      <div class="text-center mb-16 md:mb-20" data-aos="fade-up" data-aos-duration="800">
        <p class="text-cyan-400 uppercase tracking-[4px] mb-4 font-semibold">
          Contact
        </p>

        <h2 class="text-4xl md:text-5xl font-bold">
          Let's
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-500">
            Connect
          </span>
        </h2>

        <p class="text-gray-400 mt-6 max-w-2xl mx-auto leading-8">
          Interested in collaborating, building products, or discussing development ideas? Let's connect and create something amazing.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row sm:justify-center gap-4">
          <a
            href="mailto:sahara2215365@gmail.com?subject=Contact%20via%20Portfolio&body=Hi%20Ayush,%0A%0AI%20would%20like%20to%20connect%20about..."
            class="inline-flex items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:border-cyan-400 hover:text-cyan-400"
          >
            <i class="fa-solid fa-envelope mr-2"></i> Email Me
          </a>
          <a
            href="https://wa.me/918440997281?text=Hi%20Ayush%2C%20I%20saw%20your%20portfolio%20and%20would%20like%20to%20discuss..."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:border-green-400 hover:text-green-400"
          >
            <i class="fa-brands fa-whatsapp mr-2"></i> Message on WhatsApp
          </a>
        </div>      </div>

      <!-- Toast Notification Container -->
      <div id="toast" class="fixed bottom-5 right-5 z-50 transform translate-y-24 opacity-0 transition-all duration-300 pointer-events-none">
        <div id="toast-content" class="flex items-center gap-3 px-6 py-4 rounded-2xl border backdrop-blur-xl shadow-2xl">
          <i id="toast-icon" class="text-xl"></i>
          <span id="toast-message" class="font-medium text-sm"></span>
        </div>
      </div>

      <!-- Main Grid -->
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- LEFT SIDE (Info) -->
        <div class="space-y-8" data-aos="fade-right" data-aos-duration="1000">
          
          <!-- Contact Details -->
          <div class="space-y-6">
            <% 
              const contactInfo = [
                {
                  icon: "fa-solid fa-location-dot",
                  title: "Location",
                  value: "Jaipur"
                },
                {
                  icon: "fa-solid fa-envelope",
                  title: "Email",
                  value: "sahara2215365@gmail.com"
                },
                {
                  icon: "fa-solid fa-phone",
                  title: "Phone",
                  value: "+91 8440997281"
                }
              ];
            %>
            <% contactInfo.forEach(function(item) { %>
              <div class="flex items-center gap-5 bg-white/5 border border-white/10 backdrop-blur-xl rounded-3xl p-6 hover:border-cyan-400/40 transition-all duration-300 hover:translate-x-2">
                <!-- Icon -->
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-r from-cyan-500 to-purple-500 flex items-center justify-center text-2xl text-white">
                  <i class="<%= item.icon %>"></i>
                </div>
                <!-- Text -->
                <div>
                  <p class="text-gray-400 text-sm">
                    <%= item.title %>
                  </p>
                  <h3 class="text-lg font-semibold mt-1 text-white">
                    <%= item.value %>
                  </h3>
                </div>
              </div>
            <% }); %>
          </div>

          <!-- Social Links -->
          <div class="flex gap-5 mt-10">
            <a
              href="https://github.com/AYU-17"
              target="_blank"
              rel="noopener noreferrer"
              class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl text-gray-300 hover:border-cyan-400 hover:text-cyan-400 hover:scale-105 transition-all duration-300"
            >
              <i class="fa-brands fa-github"></i>
            </a>
            <a
              href="https://www.linkedin.com/in/aayush-mittal-312660214/"
              target="_blank"
              rel="noopener noreferrer"
              class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl text-gray-300 hover:border-cyan-400 hover:text-cyan-400 hover:scale-105 transition-all duration-300"
            >
              <i class="fa-brands fa-linkedin"></i>
            </a>
            <!-- <a
              href="#"
              class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl text-gray-300 hover:border-cyan-400 hover:text-cyan-400 hover:scale-105 transition-all duration-300"
            >
              <i class="fa-brands fa-twitter"></i>
            </a> -->
          </div>

        </div>

        <!-- RIGHT SIDE (Form) -->
        <div class="relative" data-aos="fade-left" data-aos-duration="1000">
          
          <!-- Background Glow behind card -->
          <div class="absolute inset-0 bg-gradient-to-r from-cyan-500 to-purple-500 opacity-10 blur-3xl rounded-3xl"></div>

          <!-- Form Card -->
          <form id="contactForm" class="relative bg-white/5 border border-white/10 backdrop-blur-xl rounded-3xl p-6 md:p-8 space-y-6">
            
            <!-- Name -->
            <div>
              <label for="name" class="block mb-3 text-sm text-gray-400">
                Your Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Enter your name"
                required
                class="w-full bg-black/20 border border-white/10 rounded-2xl px-5 py-4 outline-none focus:border-cyan-400 transition-all duration-300 text-white"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block mb-3 text-sm text-gray-400">
                Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="Enter your email"
                required
                class="w-full bg-black/20 border border-white/10 rounded-2xl px-5 py-4 outline-none focus:border-cyan-400 transition-all duration-300 text-white"
              />
            </div>

            <!-- Subject -->
            <div>
              <label for="subject" class="block mb-3 text-sm text-gray-400">
                Subject
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                placeholder="Project discussion"
                required
                class="w-full bg-black/20 border border-white/10 rounded-2xl px-5 py-4 outline-none focus:border-cyan-400 transition-all duration-300 text-white"
              />
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block mb-3 text-sm text-gray-400">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Write your message..."
                required
                class="w-full bg-black/20 border border-white/10 rounded-2xl px-5 py-4 outline-none resize-none focus:border-cyan-400 transition-all duration-300 text-white"
              ></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              id="submitBtn"
              class="w-full py-4 rounded-2xl bg-gradient-to-r from-cyan-500 to-purple-500 font-semibold text-lg shadow-lg shadow-cyan-500/20 hover:shadow-cyan-500/40 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 flex items-center justify-center gap-3 cursor-pointer text-white"
            >
              <span>Send Message</span>
              <i id="btn-spinner" class="fa-solid fa-spinner animate-spin hidden"></i>
            </button>

          </form>

        </div>

      </div>

    </div>
  </section>
</div>

<!-- AJAX Submission and Toast Alert Scripts -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm');
    const submitBtn = document.getElementById('submitBtn');
    const spinner = document.getElementById('btn-spinner');
    
    const toast = document.getElementById('toast');
    const toastContent = document.getElementById('toast-content');
    const toastIcon = document.getElementById('toast-icon');
    const toastMessage = document.getElementById('toast-message');

    function showToast(message, isSuccess) {
      toastMessage.textContent = message;
      if (isSuccess) {
        toastContent.className = "flex items-center gap-3 px-6 py-4 rounded-2xl border border-green-500/30 bg-green-950/80 text-green-300 backdrop-blur-xl shadow-2xl";
        toastIcon.className = "fa-solid fa-circle-check text-green-400 text-xl";
      } else {
        toastContent.className = "flex items-center gap-3 px-6 py-4 rounded-2xl border border-red-500/30 bg-red-950/80 text-red-300 backdrop-blur-xl shadow-2xl";
        toastIcon.className = "fa-solid fa-circle-exclamation text-red-400 text-xl";
      }
      
      // Animate slide in
      toast.classList.remove('translate-y-24', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
      
      setTimeout(() => {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('translate-y-24', 'opacity-0');
      }, 4000);
    }

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Change button state
        submitBtn.disabled = true;
        spinner.classList.remove('hidden');
        submitBtn.classList.add('opacity-80');
        
        const formData = {
          name: document.getElementById('name').value,
          email: document.getElementById('email').value,
          subject: document.getElementById('subject').value,
          message: document.getElementById('message').value
        };

        try {
          const response = await fetch('/contact', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
          });
          
          const result = await response.json();
          
          if (response.ok && result.success) {
            showToast(result.message || 'Message sent successfully!', true);
            form.reset();
          } else {
            showToast(result.message || 'Failed to send message. Please try again.', false);
          }
        } catch (error) {
          console.error('Submission error:', error);
          showToast('An error occurred. Please verify your connection.', false);
        } finally {
          submitBtn.disabled = false;
          spinner.classList.add('hidden');
          submitBtn.classList.remove('opacity-80');
        }
      });
    }
  });
</script>

<%- include('partials/footer') %>
