<%- include('partials/header', { title: 'Skills' }) %>
<%- include('partials/navbar', { activePage: 'skills' }) %>

<div class="bg-[#0f172a] text-white overflow-hidden min-h-screen pt-20 flex items-center">
  <section class="relative py-16 md:py-28 overflow-hidden w-full">
    
    <!-- Background Glows -->
    <div class="absolute top-0 left-0 w-[300px] h-[300px] bg-cyan-500/10 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-0 right-0 w-[300px] h-[300px] bg-purple-500/10 blur-[120px] rounded-full"></div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
      
      <!-- Section Heading -->
      <div class="text-center mb-16 md:mb-20" data-aos="fade-up" data-aos-duration="800">
        <p class="text-cyan-400 uppercase tracking-[4px] mb-4 font-semibold">
          Expertise
        </p>

        <h2 class="text-4xl md:text-5xl font-bold">
          Skills &
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-500">
            Technologies
          </span>
        </h2>

        <p class="text-gray-400 mt-6 max-w-2xl mx-auto leading-8">
          Modern technologies and tools used to build scalable, realtime, and production-level applications.
        </p>

        <!-- Hint text -->
        <p class="text-cyan-400/50 text-sm mt-3 animate-pulse">
          <i class="fa-solid fa-hand-pointer mr-1"></i> Click on any skill tag to learn more
        </p>
      </div>

      <!-- Skills Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
