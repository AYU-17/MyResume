<%- include('partials/header', { title: 'Skills' }) %>
<%- include('partials/navbar', { activePage: 'skills' }) %>

<div class="bg-[#0f172a] text-white overflow-hidden min-h-screen pt-20 flex items-center">
  <section class="relative py-16 md:py-28 overflow-hidden w-full">
    
    <!-- Background Glows -->
    <div class="absolute top-0 left-0 w-[300px] h-[300px] bg-cyan-500/10 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-0 right-0 w-[300px] h-[300px] bg-purple-500/10 blur-[120px] rounded-full"></div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
      
      <!-- Section Heading -->
      <div class="text-center mb-16 md:mb-20" data-aos="fade-up" data-aos-duration="800">
        <p class="text-cyan-400 uppercase tracking-[4px] mb-4 font-semibold">
          Expertise
        </p>

        <h2 class="text-4xl md:text-5xl font-bold">
          Skills &
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-500">
            Technologies
          </span>
        </h2>

        <p class="text-gray-400 mt-6 max-w-2xl mx-auto leading-8">
          Modern technologies and tools used to build scalable, realtime, and production-level applications.
        </p>
      </div>

      <!-- Skills Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
        <% 
          const skillsData = [
            {
              title: "Frontend",
              skills: ['React', "EJS", "Tailwind CSS", "JavaScript"],
              example: "Built futuristic portfolio UI"
            },
            {
              title: "Backend",
              skills: ["Node.js", "Express.js", "Socket.IO"],
              example: "Used in Real-Time Chat App"
            },
            {
              title: "Database",
              skills: ["MongoDB", "MySQL"],
              example: "Designed scalable database systems"
            },
            {
              title: "Tools & Others",
              skills: ["Git", "Postman", "Railway", "Render"],
              example: "Deployment & cloud integrations"
            }
          ];
        %>
        <% skillsData.forEach(function(card, index) { %>
          <div 
            class="group relative"
            data-aos="fade-up"
            data-aos-duration="700"
            data-aos-delay="<%= index * 150 %>"
          >
            <!-- Glow Effect -->
            <div class="absolute inset-0 bg-gradient-to-r from-cyan-500 to-purple-500 rounded-3xl blur-xl opacity-0 group-hover:opacity-20 transition duration-500"></div>

            <!-- Card -->
            <div class="relative bg-white/5 border border-white/10 backdrop-blur-xl rounded-3xl p-8 h-full hover:border-cyan-400/50 transition duration-500 flex flex-col justify-between">
              <div>
                <!-- Card Title -->
                <h3 class="text-2xl font-bold mb-6 text-white border-b border-white/5 pb-3">
                  <%= card.title %>
                </h3>

                <!-- Skills Tags -->
                <div class="flex flex-wrap gap-2.5">
                  <% card.skills.forEach(function(skill) { %>
                    <span class="px-3 py-1.5 rounded-xl bg-white/5 border border-white/10 text-xs sm:text-sm text-gray-300 hover:border-cyan-400 hover:text-cyan-300 transition duration-300">
                      <%= skill %>
                    </span>
                  <% }); %>
                </div>
              </div>

              <!-- Example Box -->
              <div class="mt-8 p-4 rounded-2xl bg-black/30 border border-cyan-500/10">
                <p class="text-xs text-gray-400 mb-1">Project Usage</p>
                <p class="text-cyan-300 text-sm font-medium"><%= card.example %></p>
              </div>
            </div>
          </div>
        <% }); %>
      </div>

    </div>
  </section>
</div>

<%- include('partials/footer') %>
