          const skillsData = [
            {
              id: "frontend",
              title: "Frontend",
              icon: "fa-solid fa-paintbrush",
              color: "from-cyan-400 to-blue-500",
              skills: ['React', 'EJS', 'Tailwind CSS', 'JavaScript']
