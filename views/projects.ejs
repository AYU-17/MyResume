<%- include('partials/header', { title: 'Projects' }) %>
<%- include('partials/navbar', { activePage: 'projects' }) %>

<div class="bg-[#0f172a] text-white overflow-hidden min-h-screen pt-20 flex items-center">
  <section id="projects" class="relative py-16 md:py-28 overflow-hidden w-full">

    <!-- Background Glows -->
    <div class="absolute top-0 right-0 w-[300px] h-[300px] bg-cyan-500/10 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-purple-500/10 blur-[120px] rounded-full"></div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">

      <!-- Heading -->
      <div class="text-center mb-16 md:mb-20" data-aos="fade-up" data-aos-duration="800">
        <p class="text-cyan-400 uppercase tracking-[4px] mb-4 font-semibold">
          Portfolio
        </p>

        <h2 class="text-4xl md:text-5xl font-bold">
          Featured
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-500">
            Projects
          </span>
        </h2>

        <p class="text-gray-400 mt-6 max-w-2xl mx-auto leading-8">
          Production-level applications focused on realtime systems, scalable backend architecture, and premium UI experiences.
        </p>
      </div>

      <!-- Project Cards Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <% 
          const projects = [
            {
              title: "Chat Application",
              description: "Realtime messaging platform with authentication, online users, typing indicator and modern chat interface.",
              image: "https://images.unsplash.com/photo-1611746872915-64382b5c76da",
              tech: ["React", "Node.js", "Socket.IO", "MySQL", "JWT"],
              github: "https://github.com/AYU-17/Socket.ly",
              demo: "#",
              page: "/projects/chat"
            },
            {
              title: "Mustard Invoice Web App",
              description: "Business invoice platform with dynamic calculations, client management and payment tracking system.",
              image: "https://images.unsplash.com/photo-1554224155-6726b3ff858f",
              tech: ["Ejs", "Node.js"],
              github: "https://github.com/AYU-17/Khata",
              demo: "#",
              page: "/projects/invoice"
            },
            {
              title: "Sales Management System",
              description: "A comprehensive sales management system for tracking leads, managing customer relationships, and analyzing sales performance.",
              image: "/assets/sales-management-system.png",
              tech: ["React", "Node.js", "MySQL", "Express", "JWT"],
              github: "https://github.com/AYU-17/sales-management-system",
              demo: "#",
              page: "/projects/sales-management"
            },
            {
              title: "Student Management System",
              description: "Admin dashboard with CRUD operations, student handling, email integration and secure management system.",
              image: "https://images.unsplash.com/photo-1552664730-d307ca884978",
              tech: ["React", "Express", "MySQL", "Node.js"],
              github: "#",
              demo: "#",
              page: "/projects/student-management-system"
            },
            {
              title: "Cine Wallet - Movie Ticket Booking App",
              description: "User-friendly movie ticket booking application with real-time seat selection, secure payment integration, and personalized recommendations.",
              image: "/assets/cine_wallet.png",
              tech: ["React", "Node.js", "MySQL", "Express", "JWT"],
              github: "https://github.com/AYU-17/Cine-Wallet",
              demo: "#",
              page: "/projects/cine-wallet"
            }
          ];
        %>
        <% projects.forEach(function(project, index) { %>
          <div 
            class="group relative flex flex-col h-full"
            data-aos="fade-up"
            data-aos-duration="700"
            data-aos-delay="<%= index * 150 %>"
          >
            <!-- Hover Glow Overlay -->
            <div class="absolute inset-0 rounded-3xl bg-gradient-to-r from-cyan-500 to-purple-500 blur-xl opacity-0 group-hover:opacity-20 transition duration-500"></div>

            <!-- Card Body -->
            <div class="relative bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl overflow-hidden hover:border-cyan-400/40 transition duration-500 flex flex-col h-full justify-between">
              
              <div>
                <!-- Image Wrapper -->
                <div class="overflow-hidden h-56 relative">
                  <img
                    src="<%= project.image %>"
                    alt="<%= project.title %>"
                    class="w-full h-full object-cover group-hover:scale-110 transition duration-700"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                </div>

                <!-- Text Details -->
                <div class="p-3 md:p-8">
                  <h3 class="text-2xl font-bold mb-3 hover:text-cyan-300 transition-colors duration-300">
                    <%= project.title %>
                  </h3>

                  <p class="text-gray-400 leading-7 mb-6 text-sm">
                    <%= project.description %>
                  </p>

                  <!-- Tech Tags -->
                  <div class="flex flex-wrap gap-2 mb-6">
                    <% project.tech.forEach(function(tech) { %>
                      <span class="px-3 py-1.5 rounded-xl bg-black/30 border border-white/10 text-xs text-cyan-300">
                        <%= tech %>
                      </span>
                    <% }); %>
                  </div>
                </div>
              </div>

              <!-- Action Buttons -->
              <div class="p-6 pt-0 flex items-center gap-3 flex-wrap">
                <a
                  href="<%= project.github %>"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 px-4 py-2.5 rounded-2xl bg-white/5 border border-white/10 hover:border-cyan-400 transition-all duration-300 hover:scale-[1.03] text-sm"
                >
                  <i class="fa-brands fa-github text-base"></i>
                  <span class="font-medium">GitHub</span>
                </a>

                <% if (project.demo !== '#') { %>
                <a
                  href="<%= project.demo %>"
                  class="flex items-center gap-1.5 px-4 py-2.5 rounded-2xl bg-gradient-to-r from-cyan-500 to-purple-500 hover:scale-105 transition-all duration-300 active:scale-95 shadow-md shadow-cyan-500/10 text-sm"
                >
                  <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
                  <span class="font-semibold">Live</span>
                </a>
                <% } %>

                <a
                  href="<%= project.page %>"
                  class="flex items-center gap-1.5 px-4 py-2.5 rounded-2xl bg-white/5 border border-white/10 hover:border-purple-400 hover:bg-purple-500/10 transition-all duration-300 hover:scale-[1.03] text-sm <%= project.page === '#' ? 'opacity-40 cursor-not-allowed' : '' %>"
                  <%= project.page === '#' ? '' : '' %>
                >
                  <i class="fa-solid fa-arrow-right text-xs"></i>
                  <span class="font-medium">View Details</span>
                </a>
              </div>

            </div>
          </div>
        <% }); %>
      </div>

    </div>
  </section>
</div>

<%- include('partials/footer') %>
