<!-- Navbar -->
<nav class="fixed top-0 left-0 w-full z-50 backdrop-blur-xl bg-black/20 border-b border-white/10">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-2xl md:text-3xl font-bold cursor-pointer transition-transform hover:scale-[1.03] inline-block">
      <span class="text-white">Aayush</span>
      <span class="text-cyan-400">Mittal</span>
    </a>

    <!-- Desktop Navigation Links -->
    <ul class="hidden md:flex items-center gap-8">
      <% 
        const navLinks = [
          { label: "Home", path: "/" },
          { label: "About", path: "/about" },
          { label: "Skills", path: "/skills" },
          { label: "Projects", path: "/projects" },
          { label: "Contact", path: "/contact" },
        ];
      %>
      <% navLinks.forEach(function(link) { %>
        <li class="relative text-gray-300 hover:text-cyan-400 transition duration-300 cursor-pointer group">
          <a href="<%= link.path %>" class="<%= typeof activePage !== 'undefined' && activePage === link.label.toLowerCase() ? 'text-cyan-400 font-semibold' : '' %>">
            <%= link.label %>
          </a>
          <span class="absolute left-0 -bottom-1 w-0 h-[2px] bg-cyan-400 transition-all duration-300 group-hover:w-full <%= typeof activePage !== 'undefined' && activePage === link.label.toLowerCase() ? 'w-full' : '' %>"></span>
        </li>
      <% }); %>
    </ul>

    <!-- Resume Button -->
    <a href="/assets/Aayush's-resume-02.pdf" class="hidden md:block px-6 py-3 rounded-2xl bg-gradient-to-r from-cyan-500 to-purple-500 text-white font-semibold shadow-lg shadow-cyan-500/20 hover:shadow-cyan-500/40 transition-all duration-300 hover:scale-[1.03] active:scale-[0.97]">
      Download Resume
    </a>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-3xl text-white cursor-pointer focus:outline-none"
      aria-label="Toggle menu"
    >
      ☰
    </button>
  </div>

  <!-- Mobile Menu Drawer -->
  <div id="mobile-menu" class="hidden md:hidden bg-black/95 border-t border-white/10">
    <ul class="flex flex-col gap-4 px-6 py-5">
      <% navLinks.forEach(function(link) { %>
        <li class="text-lg">
          <a href="<%= link.path %>" class="block w-full text-gray-200 hover:text-cyan-400 transition duration-200 <%= typeof activePage !== 'undefined' && activePage === link.label.toLowerCase() ? 'text-cyan-400 font-semibold' : '' %>">
            <%= link.label %>
          </a>
        </li>
      <% }); %>
      <li class="mt-2">
        <a href="/assets/Aayush's-resume-02.pdf" class="block text-center px-4 py-3 rounded-2xl bg-gradient-to-r from-cyan-500 to-purple-500 text-white font-semibold shadow-lg shadow-cyan-500/20 hover:shadow-cyan-500/40 transition duration-300">
          Download Resume
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    
    if (btn && menu) {
      btn.addEventListener('click', () => {
        const isHidden = menu.classList.toggle('hidden');
        btn.textContent = isHidden ? '☰' : '✕';
      });
    }
  });
</script>
